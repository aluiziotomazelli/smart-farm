CompileFlags:
  CompilationDatabase: "build"
  Add:
    - "--target=riscv32-esp-elf"
    - "-isystem"
    - "/home/german/.espressif/tools/riscv32-esp-elf/esp-14.2.0_20241119/riscv32-esp-elf/riscv32-esp-elf/include"
    - "-isystem"
    - "/home/german/.espressif/tools/riscv32-esp-elf/esp-14.2.0_20241119/riscv32-esp-elf/riscv32-esp-elf/include/c++/14.2.0"
    - "-isystem"
    - "/home/german/.espressif/tools/riscv32-esp-elf/esp-14.2.0_20241119/riscv32-esp-elf/riscv32-esp-elf/include/c++/14.2.0/riscv32-esp-elf"
  Remove:
    - -fno-tree-switch-conversion
    - -mno-esp-function-prologue
    - -mlong-calls
    - -fstrict-volatile-bitfields